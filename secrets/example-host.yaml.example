# Per-host secrets. Copy to secrets/<hostname>.yaml, edit, then encrypt:
#
#   age -e -R ~/.ssh/id_ed25519.pub -R <host-ssh-key>.pub \
#     -o secrets/<hostname>.yaml.age secrets/<hostname>.yaml
#
# To decrypt for editing:
#   age -d -i ~/.ssh/id_ed25519 secrets/<hostname>.yaml.age > secrets/<hostname>.yaml
#
# Only .age files are committed. Plaintext YAML is gitignored.

8x8-keys:
  app-id: "vpaas-magic-cookie-your-app-id-here"
  key-id: "vpaas-magic-cookie-your-app-id-here/your-key-id"
  private-key: |
    -----BEGIN PRIVATE KEY-----
    your RSA private key here
    -----END PRIVATE KEY-----
  public-key: |
    -----BEGIN PUBLIC KEY-----
    your RSA public key here
    -----END PUBLIC KEY-----

recording:
  webdav-url: "https://nextcloud.example.com/remote.php/dav/files/username"
  webdav-user: "username"
  webdav-password: "app-password-from-nextcloud"
  webhook-token: "random-token-matching-8x8-console"
